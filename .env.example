# Скопируйте в .env и заполните. Все переменные опциональны.

# LLM-провайдер: anthropic | custom | mock | none (none = полностью оффлайн)
# custom — любой OpenAI-совместимый API (DeepSeek, Qwen, Mistral, OpenRouter,
# локальные Ollama/vLLM/LM Studio и т.п.): свой ключ, адрес и модель ниже.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=

# Только для LLM_PROVIDER=custom. Пример:
#   LLM_PROVIDER=custom
#   LLM_BASE_URL=https://api.deepseek.com/v1     # база API вашего провайдера
#   LLM_API_KEY=sk-...                           # ваш ключ (Ollama — пусто)
#   LLM_MODEL=deepseek-chat
LLM_BASE_URL=
LLM_API_KEY=

# Путь к каталогу данных задачи (отчёты «Хвосты *.xlsx», справка, эталоны)
DATA_DIR=../Задача 1. Фабрика гипотез/Задача 1

# Персистентность gateway: 1 = снапшот в output/state.json, 0 = только память
HF_PERSIST=1

# Авторизация API: если задан, все запросы требуют заголовок X-API-Key
HF_API_KEY=
