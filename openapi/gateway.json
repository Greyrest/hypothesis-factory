    "/api/v1/plants/{plant}/whatif": {
      "get": {
        "summary": "Whatif",
        "description": "Контрфактуальный анализ: «если устранить N% потерь сигнала S,\nнасколько снизятся потери с хвостами».",
        "operationId": "whatif_api_v1_plants__plant__whatif_get",
        "parameters": [
          {
            "name": "plant",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Plant"
            }
          },
          {
            "name": "signal",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Signal"
            }
          },
          {
            "name": "reduction_pct",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "maximum": 100,
              "minimum": 0,
              "default": 50.0,
              "title": "Reduction Pct"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
