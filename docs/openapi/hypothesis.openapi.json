{
  "openapi": "3.1.0",
  "info": {
    "title": "Hypothesis Factory · Hypothesis Service",
    "description": "Generates falsifiable hypotheses and ranks them independently of storage and UI.",
    "version": "2.0.0"
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Service Health",
        "operationId": "service_health_api_v1_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Service Health Api V1 Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/generations": {
      "post": {
        "tags": [
          "Generation"
        ],
        "summary": "Generate and rank hypotheses",
        "operationId": "generate_hypotheses_api_v1_generations_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Generate Hypotheses Api V1 Generations Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/rankings": {
      "post": {
        "tags": [
          "Ranking"
        ],
        "summary": "Re-rank existing hypotheses",
        "operationId": "rerank_api_v1_rankings_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RerankPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Rerank Api V1 Rankings Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GenerationRequest": {
        "properties": {
          "project_id": {
            "type": "string",
            "title": "Project Id"
          },
          "domain": {
            "type": "string",
            "title": "Domain"
          },
          "target_kpi": {
            "type": "string",
            "title": "Target Kpi"
          },
          "constraints": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Constraints"
          },
          "ingestion": {
            "additionalProperties": true,
            "type": "object",
            "title": "Ingestion"
          },
          "knowledge": {
            "additionalProperties": true,
            "type": "object",
            "title": "Knowledge"
          },
          "model": {
            "$ref": "#/components/schemas/ModelSelection"
          },
          "weights": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "number"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Weights"
          },
          "feedback": {
            "additionalProperties": true,
            "type": "object",
            "title": "Feedback"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "project_id",
          "domain",
          "target_kpi",
          "ingestion",
          "knowledge"
        ],
        "title": "GenerationRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ModelSelection": {
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "anthropic",
              "openai",
              "ollama",
              "mock"
            ],
            "title": "Provider",
            "default": "anthropic"
          },
          "model": {
            "type": "string",
            "title": "Model",
            "default": "claude-opus-4-8"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": false
          },
          "base_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Base Url"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "ModelSelection"
      },
      "RerankPayload": {
        "properties": {
          "hypotheses": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Hypotheses"
          },
          "weights": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Weights"
          },
          "feedback": {
            "additionalProperties": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "object",
            "title": "Feedback"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "hypotheses"
        ],
        "title": "RerankPayload"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}