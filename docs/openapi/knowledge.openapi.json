{
  "openapi": "3.1.0",
  "info": {
    "title": "Hypothesis Factory · Knowledge Service",
    "description": "Builds retrieval context, evidence graphs, and hypothesis traces.",
    "version": "2.0.0"
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Service Health",
        "operationId": "service_health_api_v1_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Service Health Api V1 Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/context": {
      "post": {
        "tags": [
          "Knowledge"
        ],
        "summary": "Build retrieval context",
        "operationId": "build_context_api_v1_context_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KnowledgeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Build Context Api V1 Context Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/graphs": {
      "post": {
        "tags": [
          "Graph"
        ],
        "summary": "Build project knowledge graph",
        "operationId": "build_graph_api_v1_graphs_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GraphRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Build Graph Api V1 Graphs Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/traces/{hypothesis_id}": {
      "post": {
        "tags": [
          "Graph"
        ],
        "summary": "Extract hypothesis trace",
        "operationId": "trace_api_v1_traces__hypothesis_id__post",
        "parameters": [
          {
            "name": "hypothesis_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Hypothesis Id"
            }
          },
          {
            "name": "depth",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 5,
              "minimum": 1,
              "default": 2,
              "title": "Depth"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "title": "Graph"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Trace Api V1 Traces  Hypothesis Id  Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FileRef": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "filename": {
            "type": "string",
            "title": "Filename"
          },
          "path": {
            "type": "string",
            "title": "Path"
          },
          "media_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Media Type"
          },
          "kind": {
            "type": "string",
            "title": "Kind",
            "default": "data"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "id",
          "filename",
          "path"
        ],
        "title": "FileRef"
      },
      "GraphRequest": {
        "properties": {
          "project": {
            "additionalProperties": true,
            "type": "object",
            "title": "Project"
          },
          "ingestion": {
            "additionalProperties": true,
            "type": "object",
            "title": "Ingestion"
          },
          "hypotheses": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Hypotheses"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "project",
          "ingestion",
          "hypotheses"
        ],
        "title": "GraphRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "KnowledgeRequest": {
        "properties": {
          "project_id": {
            "type": "string",
            "title": "Project Id"
          },
          "domain": {
            "type": "string",
            "title": "Domain"
          },
          "files": {
            "items": {
              "$ref": "#/components/schemas/FileRef"
            },
            "type": "array",
            "title": "Files"
          },
          "ingestion": {
            "additionalProperties": true,
            "type": "object",
            "title": "Ingestion"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "project_id",
          "domain",
          "files",
          "ingestion"
        ],
        "title": "KnowledgeRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}