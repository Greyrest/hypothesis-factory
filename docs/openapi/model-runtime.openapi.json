{
  "openapi": "3.1.0",
  "info": {
    "title": "Hypothesis Factory · Model Runtime",
    "description": "Provider-neutral structured generation. API keys remain in this isolated service; project services only pass provider and model identifiers.",
    "version": "2.0.0"
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Service Health",
        "operationId": "service_health_api_v1_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Service Health Api V1 Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/models": {
      "get": {
        "tags": [
          "Models"
        ],
        "summary": "List selectable models",
        "operationId": "list_models_api_v1_models_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response List Models Api V1 Models Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/enhance": {
      "post": {
        "tags": [
          "Models"
        ],
        "summary": "Enhance drafts with selected model",
        "operationId": "enhance_api_v1_enhance_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EnhanceRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Enhance Api V1 Enhance Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EnhanceRequest": {
        "properties": {
          "selection": {
            "$ref": "#/components/schemas/ModelSelection"
          },
          "diagnosis": {
            "additionalProperties": true,
            "type": "object",
            "title": "Diagnosis"
          },
          "drafts": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Drafts"
          },
          "knowledge": {
            "additionalProperties": true,
            "type": "object",
            "title": "Knowledge"
          },
          "language": {
            "type": "string",
            "title": "Language",
            "default": "ru"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "selection",
          "diagnosis",
          "drafts",
          "knowledge"
        ],
        "title": "EnhanceRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ModelSelection": {
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "anthropic",
              "openai",
              "ollama",
              "mock"
            ],
            "title": "Provider",
            "default": "anthropic"
          },
          "model": {
            "type": "string",
            "title": "Model",
            "default": "claude-opus-4-8"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": false
          },
          "base_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Base Url"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "ModelSelection"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}